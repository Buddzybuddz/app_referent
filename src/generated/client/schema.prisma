generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Collaborateur {
  id            String   @id @default(cuid())
  nom           String
  prenom        String
  dateNaissance DateTime
  dateEntree    DateTime @default(now())

  // Accès & Identité
  email String? @unique
  role  String  @default("NONE") // NONE, USER, ADMIN

  // Infos Perso
  telephone    String?
  ville        String?
  site         String?
  leaderActuel String?

  // Hiérarchie (Un référent est un collaborateur qui en suit d'autres)
  referentId String?
  referent   Collaborateur?  @relation("Hierarchie", fields: [referentId], references: [id])
  equipe     Collaborateur[] @relation("Hierarchie")

  // Données de suivi
  projets     Projet[]
  competences Competence[]
  entretiens  Entretien[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Contrôle d'unicité par triplet Nom/Prénom/DateNaissance
  @@unique([nom, prenom, dateNaissance])
}

model Projet {
  id              String        @id @default(cuid())
  nom             String
  description     String?
  dateDebut       DateTime
  dateFin         DateTime?
  collaborateur   Collaborateur @relation(fields: [collaborateurId], references: [id], onDelete: Cascade)
  collaborateurId String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Competence {
  id              String        @id @default(cuid())
  nom             String
  acquise         Boolean       @default(false)
  collaborateur   Collaborateur @relation(fields: [collaborateurId], references: [id], onDelete: Cascade)
  collaborateurId String
}

model Entretien {
  id              String        @id @default(cuid())
  date            DateTime
  type            String // PPER, CARRIERE, etc.
  statut          String // FAIT, A_FAIRE
  compteRendu     String?
  collaborateur   Collaborateur @relation(fields: [collaborateurId], references: [id], onDelete: Cascade)
  collaborateurId String
}
