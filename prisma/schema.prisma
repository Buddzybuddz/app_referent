generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Collaborateur {
  id            String          @id @default(cuid())
  nom           String
  prenom        String
  dateNaissance DateTime
  dateEntree    DateTime        @default(now())
  email         String?         @unique
  isRefere      Boolean         @default(false)
  isReferent    Boolean         @default(false)
  isAdmin       Boolean         @default(false)
  telephone     String?
  ville         String?
  site          String?
  leaderActuel  String?
  referentId    String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  referent      Collaborateur?  @relation("Hierarchie", fields: [referentId], references: [id])
  equipe        Collaborateur[] @relation("Hierarchie")
  competences   Competence[]
  entretiens    Entretien[]
  projets       Projet[]

  @@unique([nom, prenom, dateNaissance])
}

model Projet {
  id              String        @id @default(cuid())
  nom             String
  description     String?
  dateDebut       DateTime
  dateFin         DateTime?
  collaborateurId String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  collaborateur   Collaborateur @relation(fields: [collaborateurId], references: [id], onDelete: Cascade)
}

model Competence {
  id              String        @id @default(cuid())
  nom             String
  acquise         Boolean       @default(false)
  collaborateurId String
  collaborateur   Collaborateur @relation(fields: [collaborateurId], references: [id], onDelete: Cascade)
}

model Entretien {
  id              String        @id @default(cuid())
  date            DateTime
  type            String
  statut          String
  compteRendu     String?
  collaborateurId String
  collaborateur   Collaborateur @relation(fields: [collaborateurId], references: [id], onDelete: Cascade)
}
